{
  "version": 2,
  "github": {
    "silent": true
  },
  "ignoreCommand": "git diff HEAD^ HEAD --name-only | grep -qvE '^data/'",
  "headers": [
    {
      "source": "/world-market.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/(favicon.ico|icon-t-.*\\.png|apple-touch-icon.*\\.png|site.webmanifest)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ],
  "functions": {
    "api/kis-realtime-data.js": {
      "maxDuration": 60
    },
    "api/us-market-data.js": {
      "maxDuration": 60
    },
    "api/crypto-data.js": {
      "maxDuration": 60
    },
    "api/stock-analysis.js": {
      "maxDuration": 60
    },
    "api/world-market.js": {
      "maxDuration": 60
    },
    "api/repo-data.js": {
      "maxDuration": 15
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/apple-touch-icon.png", "dest": "/icon-t-180.png" },
    { "src": "/apple-touch-icon-precomposed.png", "dest": "/icon-t-180.png" },
    { "src": "/apple-touch-icon-180x180.png", "dest": "/icon-t-180.png" },
    { "src": "/apple-touch-icon-152x152.png", "dest": "/icon-t-180.png" },
    { "src": "/apple-touch-icon-120x120.png", "dest": "/icon-t-180.png" },
    { "src": "/briefing.html", "dest": "/briefing.html" },
    { "src": "/realtime.html", "dest": "/realtime.html" },
    { "src": "/daily-market.html", "dest": "/daily-market.html" },
    { "src": "/weekly-market.html", "dest": "/weekly-market.html" },
    { "src": "/weekly-market/?", "dest": "/weekly-market.html" },
    { "src": "/us-market.html", "dest": "/us-market.html" },
    { "src": "/crypto.html", "dest": "/crypto.html" },
    { "src": "/world-market.html", "dest": "/world-market.html" },
    { "src": "/stock-analysis.html", "dest": "/stock-analysis.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
