{
  "version": 2,
  "headers": [
    {
      "source": "/world-market.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    }
  ],
  "functions": {
    "api/kis-realtime-data.js": {
      "maxDuration": 60
    },
    "api/us-market-data.js": {
      "maxDuration": 60
    },
    "api/crypto-data.js": {
      "maxDuration": 60
    },
    "api/world-market.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/briefing.html", "dest": "/briefing.html" },
    { "src": "/realtime.html", "dest": "/realtime.html" },
    { "src": "/daily-market.html", "dest": "/daily-market.html" },
    { "src": "/weekly-market.html", "dest": "/weekly-market.html" },
    { "src": "/weekly-market/?", "dest": "/weekly-market.html" },
    { "src": "/us-market.html", "dest": "/us-market.html" },
    { "src": "/crypto.html", "dest": "/crypto.html" },
    { "src": "/world-market.html", "dest": "/world-market.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
